{
  "name": "@acarmisc/backstage-plugin-litellm-chat-backend",
  "version": "0.2.1",
  "description": "Backstage backend plugin for LiteLLM RAG chat — streaming proxy + vector store listing.",
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "litellm-chat",
    "pluginPackages": [
      "@acarmisc/backstage-plugin-litellm-chat-backend"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs.js"
    }
  },
  "main": "dist/index.cjs.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "config.d.ts"
  ],
  "scripts": {
    "build": "node build.js && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "postpack": ""
  },
  "dependencies": {
    "@acarmisc/backstage-plugin-litellm-backend": "^0.3.4",
    "@backstage/backend-plugin-api": "^1.9.1",
    "@backstage/config": "^1.3.0",
    "@backstage/types": "^1.2.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.2",
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "winston": "^3.17.0"
  },
  "configSchema": "config.d.ts"
}
