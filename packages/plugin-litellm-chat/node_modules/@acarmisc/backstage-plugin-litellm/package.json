{
  "name": "@acarmisc/backstage-plugin-litellm",
  "version": "0.4.0",
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "litellm",
    "pluginPackages": [
      "@acarmisc/backstage-plugin-litellm"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
